# ============================================================
# .env.example — Plantilla de Variables de Entorno
# Serverless Solar MLOps | Sub-fase 0.1
# ============================================================
# INSTRUCCIONES:
#   1. Copiar este archivo como ".env":  cp .env.example .env
#   2. Rellenar cada valor con los datos reales de tu proyecto GCP.
#   3. NUNCA versionar el archivo .env (ya está en .gitignore).
# ============================================================

# --------------- Google Cloud Platform ---------------
GCP_PROJECT_ID=tu-proyecto-gcp
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# --------------- BigQuery (Capa Oro) ---------------
BQ_DATASET_GOLD=gold_layer
BQ_TABLE_TIMESERIES=solar_timeseries

# --------------- Vertex AI ---------------
VERTEX_STAGING_BUCKET=gs://tu-bucket-staging
VERTEX_TENSORBOARD_INSTANCE=projects/tu-proyecto/locations/us-central1/tensorboards/12345
VERTEX_SERVICE_ACCOUNT=vertex-sa@tu-proyecto-gcp.iam.gserviceaccount.com

# --------------- Entrenamiento (Hiperparámetros por defecto) ---------------
TRAIN_EPOCHS=100
TRAIN_BATCH_SIZE=64
TRAIN_LEARNING_RATE=0.001
TRAIN_SEQUENCE_LENGTH=168
TRAIN_FORECAST_HORIZON=24

# --------------- Modelo ---------------
MODEL_TYPE=transformer_bilstm
MODEL_D_MODEL=128
MODEL_N_HEADS=8
MODEL_N_ENCODER_LAYERS=3
MODEL_LSTM_HIDDEN_SIZE=256
MODEL_DROPOUT=0.1

# --------------- Cloud Composer / Airflow ---------------
COMPOSER_ENVIRONMENT=solar-mlops-composer
COMPOSER_LOCATION=us-central1

# --------------- Logging y Observabilidad ---------------
LOG_LEVEL=INFO
STRUCTURED_LOGGING=true

# --------------- Pub/Sub (Trigger de Reentrenamiento) ---------------
PUBSUB_TOPIC=gold-layer-updated
PUBSUB_SUBSCRIPTION=gold-layer-updated-sub
